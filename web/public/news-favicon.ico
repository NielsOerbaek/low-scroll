    <script type="text/javascript">
    var logged_in = Boolean()
    var purchase_flow_url = 'https://fyens.dk/abonnement'
    
    if (purchase_flow_url.charAt(0) === '/') {
        purchase_flow_url = location.origin + purchase_flow_url;
